# =====================================================================
# Plantilla de variables de entorno. Copiar a .env y completar valores.
# El archivo .env NO se versiona (esta en .gitignore).
#
# IMPORTANTE: nunca pegues secretos en chats, capturas o documentos
# compartidos. Si se filtra alguno, rotarlo en el panel del proveedor
# y actualizar la variable correspondiente.
# =====================================================================

# --- Base de datos ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=digitalcow
MYSQL_USER=digitalcow
MYSQL_PASSWORD=cambiar-en-produccion
MYSQL_ROOT_PASSWORD=cambiar-en-produccion-tambien
# Parametros de conexion JDBC. Dev local (sin TLS) usa el valor por defecto del application.yml,
# asi que puedes dejar MYSQL_PARAMS vacio en local. Para un MySQL gestionado que exige TLS,
# define MYSQL_PARAMS con sslMode=VERIFY_IDENTITY (no agregues useSSL ni allowPublicKeyRetrieval).
# MYSQL_PARAMS=sslMode=VERIFY_IDENTITY&serverTimezone=UTC&characterEncoding=utf8
#
# --- TiDB Cloud Serverless (MySQL gestionado gratis) ---
# Tras crear el cluster, panel Connect: copia host, usuario (formato <prefijo>.root) y password,
# y reemplaza los valores de arriba por estos. El puerto de TiDB es 4000, NO 3306.
# MYSQL_HOST=gateway01.<region>.prod.aws.tidbcloud.com
# MYSQL_PORT=4000
# MYSQL_DATABASE=digitalcow
# MYSQL_USER=<prefijo>.root
# MYSQL_PASSWORD=<password-de-tidb>
# MYSQL_PARAMS=sslMode=VERIFY_IDENTITY&serverTimezone=UTC&characterEncoding=utf8

# --- Backend (autenticacion y CORS) ---
# Cadena aleatoria de al menos 32 bytes (256 bits). Generar con:
#   openssl rand -base64 48
JWT_SECRET=reemplazar-con-cadena-aleatoria-larga
# Incluye el dominio donde Vercel sirve el frontend, separados por coma.
# Admite comodines (https://*.vercel.app) para cubrir los previews de Vercel.
# Ejemplo: http://localhost:5173,https://digital-cow-client.vercel.app,https://*.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://digital-cow-client.vercel.app,https://*.vercel.app
SUPERADMIN_EMAIL=admin@digitalcow.local
# Password del superadmin creado al primer arranque. Si se deja vacia, se genera
# una aleatoria que aparece una sola vez en el log del backend.
SUPERADMIN_PASSWORD=
SPRING_PROFILES_ACTIVE=dev

# --- Cloudinary (subida de fotos firmada en backend) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Correo saliente ---
MAIL_PROVIDER=dev
MAIL_FROM=Digital Cow <no-reply@digitalcow.local>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Frontend (Vercel) ---
# Se configura en el panel de Vercel como variable de entorno, NO aqui.
# En dev local con `npm run dev`, Vite usa el proxy a localhost:8080 y
# esta variable es opcional. En produccion debe apuntar al backend publico:
#   VITE_API_URL=https://api.tu-dominio.com/api/v1
VITE_API_URL=http://localhost:8080/api/v1
