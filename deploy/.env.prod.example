# Plantilla de variables para produccion en VPS.
# Copiar como .env en /opt/digital-cow/.env y completar.
# Permisos recomendados: chmod 600 .env y propietario root.

# --- Acceso publico ---
# El backend se expone via Nginx en HTTP por la IP del VPS (puerto 80).
# Si en el futuro se anade un dominio + HTTPS, ajustar nginx.conf y abrir 443.

# --- Base de datos (gestionada: TiDB Cloud) ---
# Copiar host, usuario (formato <prefijo>.root) y password del panel Connect de TiDB.
# El puerto de TiDB es 4000. Requiere TLS via MYSQL_PARAMS.
MYSQL_HOST=gateway01.<region>.prod.aws.tidbcloud.com
MYSQL_PORT=4000
MYSQL_DATABASE=digitalcow
MYSQL_USER=<prefijo>.root
MYSQL_PASSWORD=poner-password-de-tidb
MYSQL_PARAMS=sslMode=VERIFY_IDENTITY&serverTimezone=UTC&characterEncoding=utf8

# --- Autenticacion ---
# Cadena aleatoria de >= 256 bits. Generar con: openssl rand -base64 48
JWT_SECRET=reemplazar-con-cadena-aleatoria-larga

# --- CORS ---
# Incluye el dominio del frontend en Vercel separado por comas si hay varios.
# Importante: poner el scheme (https://) y SIN slash final.
CORS_ALLOWED_ORIGINS=https://digital-cow-client.vercel.app

# --- Super admin inicial ---
SUPERADMIN_EMAIL=admin@digitalcow.local
# Si se deja vacia, se genera una password aleatoria visible una sola vez en el log.
SUPERADMIN_PASSWORD=

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Correo saliente (Resend recomendado en produccion) ---
MAIL_PROVIDER=resend
MAIL_FROM=Digital Cow <no-reply@digitalcow.local>
RESEND_API_KEY=

# Solo si usas SMTP en vez de Resend:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
