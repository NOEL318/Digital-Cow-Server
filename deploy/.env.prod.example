# Plantilla de variables para produccion en VPS.
# Copiar como .env en /opt/digital-cow/.env y completar.
# Permisos recomendados: chmod 600 .env y propietario root.

# --- Dominio publico ---
# Dominio que apunta a la IP del VPS via registro A. Caddy lo usa para obtener TLS.
DOMAIN=api.tudominio.com

# --- Base de datos ---
MYSQL_DATABASE=digitalcow
MYSQL_USER=digitalcow
MYSQL_PASSWORD=poner-password-fuerte-aqui
MYSQL_ROOT_PASSWORD=poner-otro-password-fuerte-aqui

# --- Autenticacion ---
# Cadena aleatoria de >= 256 bits. Generar con: openssl rand -base64 48
JWT_SECRET=reemplazar-con-cadena-aleatoria-larga

# --- CORS ---
# Incluye el dominio del frontend en Vercel separado por comas si hay varios.
CORS_ALLOWED_ORIGINS=https://digital-cow.vercel.app

# --- Super admin inicial ---
SUPERADMIN_EMAIL=admin@tudominio.com

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Correo saliente (Resend recomendado en produccion) ---
MAIL_PROVIDER=resend
MAIL_FROM=Digital Cow <no-reply@tudominio.com>
RESEND_API_KEY=

# Solo si usas SMTP en vez de Resend:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
